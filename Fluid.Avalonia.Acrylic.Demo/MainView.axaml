<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:acrylic="using:Fluid.Avalonia.Acrylic"
             x:Class="AcrylicDemo.MainView"
             Background="#111111">

  <TabControl x:Name="Tabs" Padding="0" Margin="0">

    <!-- ===================== GALLERY ===================== -->
    <TabItem Header="Gallery">
      <Panel>
        <Panel>
          <Panel.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#E54D2E" Offset="0"/>
              <GradientStop Color="#E93D82" Offset="0.5"/>
              <GradientStop Color="#3B9EFF" Offset="1"/>
            </LinearGradientBrush>
          </Panel.Background>
          <Ellipse Width="240" Height="240" Fill="#8CFFD60A" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="70,40,0,0"/>
          <Ellipse Width="320" Height="320" Fill="#80FF801F" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,80,40"/>
          <Ellipse Width="200" Height="200" Fill="#7C71D083" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-40,0,0"/>
        </Panel>
        <StackPanel Orientation="Horizontal" Spacing="28" HorizontalAlignment="Center" VerticalAlignment="Center">
          <acrylic:AcrylicSurface Width="300" Height="340" CornerRadius="28" BlurRadius="16" Vibrancy="1.4" Brightness="0.06" TintColor="#5472E4" HighlightEnabled="True" ShadowEnabled="True">
            <StackPanel Margin="28" VerticalAlignment="Center">
              <TextBlock Text="Cross-platform" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
              <TextBlock Text="Windows, macOS, Linux &amp; WASM — identical output." FontSize="14" Foreground="#ECFFFFFF" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
          </acrylic:AcrylicSurface>
          <acrylic:AcrylicSurface Width="300" Height="340" CornerRadius="28" BlurRadius="16" Vibrancy="1.4" Brightness="0.06" TintColor="#B658C4" HighlightEnabled="True" ShadowEnabled="True">
            <StackPanel Margin="28" VerticalAlignment="Center">
              <TextBlock Text="No OS backdrop" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
              <TextBlock Text="No Mica, vibrancy or KWin blur required." FontSize="14" Foreground="#ECFFFFFF" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
          </acrylic:AcrylicSurface>
          <acrylic:AcrylicSurface Width="300" Height="340" CornerRadius="28" BlurRadius="16" Vibrancy="1.4" Brightness="0.06" TintColor="#1FD8A4" HighlightEnabled="True" ShadowEnabled="True">
            <StackPanel Margin="28" VerticalAlignment="Center">
              <TextBlock Text="Pure SkiaSharp" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
              <TextBlock Text="One SKRuntimeEffect shader, GPU or CPU." FontSize="14" Foreground="#ECFFFFFF" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
          </acrylic:AcrylicSurface>
        </StackPanel>
      </Panel>
    </TabItem>

    <!-- ===================== PLAYGROUND ===================== -->
    <TabItem Header="Playground">
      <Grid ColumnDefinitions="*,320">
        <Panel Grid.Column="0">
          <Panel>
            <Panel.Background>
              <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#8E4EC6" Offset="0"/>
                <GradientStop Color="#5B5BD6" Offset="0.55"/>
                <GradientStop Color="#00A2C7" Offset="1"/>
              </LinearGradientBrush>
            </Panel.Background>
            <Ellipse Width="280" Height="280" Fill="#80DE51A8" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="40,0,0,30"/>
            <Ellipse Width="300" Height="300" Fill="#80FFC53D" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,30,40,0"/>
          </Panel>
          <acrylic:AcrylicSurface x:Name="PlayCard" Width="440" Height="300" CornerRadius="28" BlurRadius="14" Vibrancy="1.4" Brightness="0.06" TintColor="#5472E4" HighlightEnabled="True" ShadowEnabled="True" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Margin="32" VerticalAlignment="Center">
              <TextBlock Text="Playground" FontSize="26" FontWeight="SemiBold" Foreground="White"/>
              <TextBlock Text="Tune the glass with the controls on the right, then screenshot." FontSize="14" Foreground="#ECFFFFFF" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
          </acrylic:AcrylicSurface>
        </Panel>
        <Border Grid.Column="1" Background="#13131E" Padding="22">
          <StackPanel Spacing="4">
            <TextBlock Text="Blur radius" Foreground="#B0B4BA" Margin="0,0,0,2"/>
            <Slider x:Name="BlurSlider" Minimum="0" Maximum="40" Value="14"/>
            <TextBlock Text="Vibrancy" Foreground="#B0B4BA" Margin="0,8,0,2"/>
            <Slider x:Name="VibSlider" Minimum="0" Maximum="3" Value="1.4"/>
            <TextBlock Text="Brightness" Foreground="#B0B4BA" Margin="0,8,0,2"/>
            <Slider x:Name="BrightSlider" Minimum="-0.3" Maximum="0.3" Value="0.06"/>
            <CheckBox x:Name="HighlightCheck" Content="Edge highlight" IsChecked="True" Margin="0,8,0,0"/>
            <CheckBox x:Name="ShadowCheck" Content="Drop shadow" IsChecked="True"/>
            <TextBlock Text="Tint" Foreground="#B0B4BA" Margin="0,12,0,6"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Button Click="OnSwatch" Tag="#5472E4" Background="#5472E4" Width="32" Height="32" CornerRadius="7"/>
              <Button Click="OnSwatch" Tag="#B658C4" Background="#B658C4" Width="32" Height="32" CornerRadius="7"/>
              <Button Click="OnSwatch" Tag="#1FD8A4" Background="#1FD8A4" Width="32" Height="32" CornerRadius="7"/>
              <Button Click="OnSwatch" Tag="#EC5A72" Background="#EC5A72" Width="32" Height="32" CornerRadius="7"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </TabItem>

    <!-- ===================== INTERACTIVE ===================== -->
    <TabItem Header="Interactive">
      <Panel>
        <Panel>
          <Panel.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#111A27" Offset="0"/>
              <GradientStop Color="#2E3135" Offset="0.5"/>
              <GradientStop Color="#1E685F" Offset="1"/>
            </LinearGradientBrush>
          </Panel.Background>
          <Ellipse Width="260" Height="260" Fill="#8C4CCCE6" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="120,80,0,0"/>
          <Ellipse Width="320" Height="320" Fill="#805472E4" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,80,40"/>
        </Panel>
        <Canvas x:Name="InteractiveCanvas">
          <acrylic:AcrylicInteractiveSurface x:Name="InteractiveCard" Canvas.Left="360" Canvas.Top="170" Width="460" Height="300" CornerRadius="32" InteractiveMaxScaleDip="40" DeformOnRightButton="True" BlurRadius="18" Vibrancy="1.4" Brightness="0.06" TintColor="#4CCCE6" HighlightEnabled="True" ShadowEnabled="True">
            <StackPanel Margin="32" VerticalAlignment="Center">
              <TextBlock Text="Drag me" FontSize="26" FontWeight="SemiBold" Foreground="White"/>
              <TextBlock Text="Left-drag to move it · Right-drag to deform (squish &amp; spring)." FontSize="14" Foreground="#ECFFFFFF" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
          </acrylic:AcrylicInteractiveSurface>
        </Canvas>
      </Panel>
    </TabItem>

    <!-- ===================== REVEAL & PARALLAX ===================== -->
    <TabItem Header="Reveal &amp; Parallax">
      <Panel>
        <Panel>
          <Panel.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#11131F" Offset="0"/>
              <GradientStop Color="#262A65" Offset="0.5"/>
              <GradientStop Color="#291F43" Offset="1"/>
            </LinearGradientBrush>
          </Panel.Background>
          <Ellipse Width="260" Height="260" Fill="#805472E4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="80,60,0,0"/>
          <Ellipse Width="300" Height="300" Fill="#804CCCE6" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,60,40"/>
        </Panel>
        <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center" VerticalAlignment="Center">
          <StackPanel Spacing="14">
            <TextBlock Text="Move across this pair — one shared pointer broadcast" Foreground="#B0B4BA" FontSize="12" HorizontalAlignment="Center" Width="560"/>
            <StackPanel Orientation="Horizontal" Spacing="24">
              <acrylic:AcrylicSurface Width="260" Height="220" CornerRadius="24" BlurRadius="14" Vibrancy="1.4" Brightness="0.06" TintColor="#5472E4" HighlightEnabled="True" ShadowEnabled="True" RevealBorderEnabled="True">
                <StackPanel Margin="24" VerticalAlignment="Center">
                  <TextBlock Text="Reveal A" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                  <TextBlock Text="Glows on hover and on approach from nearby." FontSize="13" Foreground="#ECFFFFFF" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
              </acrylic:AcrylicSurface>
              <acrylic:AcrylicSurface Width="260" Height="220" CornerRadius="24" BlurRadius="14" Vibrancy="1.4" Brightness="0.06" TintColor="#4CCCE6" HighlightEnabled="True" ShadowEnabled="True" RevealBorderEnabled="True">
                <StackPanel Margin="24" VerticalAlignment="Center">
                  <TextBlock Text="Reveal B" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                  <TextBlock Text="Both surfaces share one TopLevel pointer hook." FontSize="13" Foreground="#ECFFFFFF" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
              </acrylic:AcrylicSurface>
            </StackPanel>
          </StackPanel>
          <acrylic:AcrylicParallaxSurface Width="260" Height="454" CornerRadius="24" BlurRadius="14" Vibrancy="1.4" Brightness="0.06" TintColor="#B658C4" HighlightEnabled="True" ShadowEnabled="True" ParallaxStrength="28">
            <StackPanel Margin="24" VerticalAlignment="Center">
              <TextBlock Text="Parallax" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
              <TextBlock Text="Move the pointer over this card — the sampled backdrop shifts opposite the cursor." FontSize="14" Foreground="#ECFFFFFF" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
          </acrylic:AcrylicParallaxSurface>
        </StackPanel>
      </Panel>
    </TabItem>

    <!-- ===================== IN AN APP ===================== -->
    <TabItem Header="In an app">
      <Panel>
        <Panel>
          <Panel.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#1B537B" Offset="0"/>
              <GradientStop Color="#473876" Offset="1"/>
            </LinearGradientBrush>
          </Panel.Background>
          <Ellipse Width="300" Height="300" Fill="#6CFF8DCC" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="60,0,0,40"/>
          <Ellipse Width="260" Height="260" Fill="#6C7CE2FE" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,60,80,0"/>
        </Panel>
        <Grid Margin="40" ColumnDefinitions="220,*">
          <acrylic:AcrylicSurface Grid.Column="0" Margin="0,0,20,0" CornerRadius="24" BlurRadius="20" Vibrancy="1.3" Brightness="0.05" TintColor="#5472E4" HighlightEnabled="True" ShadowEnabled="True">
            <StackPanel Margin="22" Spacing="14">
              <TextBlock Text="Acrylic" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
              <TextBlock Text="Home" Foreground="#F0FFFFFF"/>
              <TextBlock Text="Gallery" Foreground="#B8FFFFFF"/>
              <TextBlock Text="Settings" Foreground="#B8FFFFFF"/>
              <TextBlock Text="About" Foreground="#B8FFFFFF"/>
            </StackPanel>
          </acrylic:AcrylicSurface>
          <acrylic:AcrylicSurface Grid.Column="1" CornerRadius="24" BlurRadius="20" Vibrancy="1.3" Brightness="0.05" TintColor="#B658C4" HighlightEnabled="True" ShadowEnabled="True">
            <StackPanel Margin="32" Spacing="12" VerticalAlignment="Center">
              <TextBlock Text="Frosted panels in a real layout" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
              <TextBlock Text="Drop AcrylicSurface anywhere you'd use a Border or Card — it frosts whatever sits behind it." FontSize="15" Foreground="#ECFFFFFF" TextWrapping="Wrap"/>
              <Border Background="#33FFFFFF" Height="1" Margin="0,6"/>
              <TextBlock Text="• Blur, vibrancy, tint, refraction" Foreground="#E0FFFFFF"/>
              <TextBlock Text="• Edge highlight &amp; drop shadow" Foreground="#E0FFFFFF"/>
              <TextBlock Text="• Works on desktop and in the browser" Foreground="#E0FFFFFF"/>
            </StackPanel>
          </acrylic:AcrylicSurface>
        </Grid>
      </Panel>
    </TabItem>

  </TabControl>
</UserControl>
